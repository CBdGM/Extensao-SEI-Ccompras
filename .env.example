# ─────────────────────────────────────────────────────────────
# Integração Compras-SEI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o arquivo .env no repositório.
# ─────────────────────────────────────────────────────────────

# ─── Aplicação ────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ─── Segurança (OBRIGATÓRIO — gere chaves fortes) ────────────
# Gerar: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=SUBSTITUA_POR_CHAVE_SEGURA_64_BYTES

# Gerar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=SUBSTITUA_POR_CHAVE_FERNET

# ─── Banco de dados ───────────────────────────────────────────
POSTGRES_USER=compras_sei
POSTGRES_PASSWORD=SUBSTITUA_POR_SENHA_SEGURA
POSTGRES_DB=compras_sei
# Para conexão direta (sem Docker):
# DATABASE_URL=postgresql+asyncpg://compras_sei:SENHA@localhost:5432/compras_sei

# ─── CORS ─────────────────────────────────────────────────────
# Lista separada por vírgula (não usar colchetes JSON)
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,https://seudominio.edu.br

# ─── Upload de arquivos ───────────────────────────────────────
MAX_FILE_SIZE_MB=20

# ─── Integração SEI (opcional — pode configurar pelo painel) ──
# Se configurado aqui, tem precedência sobre o banco de dados.
SEI_SOAP_URL=
SEI_SIGLA_SISTEMA=
# ATENÇÃO: Nunca exponha a chave de acesso publicamente
SEI_IDENTIFICACAO_SERVICO=
SEI_ID_UNIDADE_DEFAULT=

# ─── Operações de escrita no SEI (DESABILITADO por padrão) ────
# ATENÇÃO: Habilitar apenas após validação completa com equipe SEI
SEI_ENABLE_WRITE_OPERATIONS=false

# ─── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=10
